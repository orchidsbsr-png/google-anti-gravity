{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "google-anti-gravity.vercel.app"
        }
      ],
      "destination": "https://nalibanfarms.in/$1",
      "permanent": false
    },
    {
      "source": "/((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": "fresh-farm-himachal.vercel.app"
        }
      ],
      "destination": "https://nalibanfarms.in/$1",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/abandoned_carts",
      "schedule": "30 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
